{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeIdentification-Comparator",
  "version": "0.1.0",
  "identifier": "com.bigdata.comparator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "비식별화 비교기",
        "width": 1200,
        "height": 900,
        "dragDropEnabled": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
